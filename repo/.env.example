# Copy this file to .env and fill in real values before deploying to production.
# Generate SECRET_KEY and HMAC_SECRET with:
#   python -c "import secrets; print(secrets.token_hex(32))"
# Generate ENCRYPTION_KEY (base64-encoded 32-byte AES key) with:
#   python -c "import base64, os; print(base64.b64encode(os.urandom(32)).decode())"

FLASK_ENV=production
SECRET_KEY=change-me-in-production-secret-key
HMAC_SECRET=change-me-in-production-hmac-secret
ENCRYPTION_KEY=AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA=
DATABASE_URL=sqlite:////app/data/clinical_ops.db
